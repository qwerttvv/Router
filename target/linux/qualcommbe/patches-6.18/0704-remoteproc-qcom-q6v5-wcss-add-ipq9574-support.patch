+static void q6v7_wcss_disable_clocks(struct q6v5_wcss *wcss)
+{
+	clk_bulk_disable_unprepare(wcss->num_clks, wcss->clks);
+	clk_bulk_disable_unprepare(wcss->num_pre_boot_clks,
+				   wcss->pre_boot_clks);
+}
