+		return NOTIFY_DONE;
+
+#if (LINUX_VERSION_CODE >= KERNEL_VERSION(6, 18, 0))
+	if (!dp->cpu_dp->conduit)
+		return NOTIFY_DONE;
+	netdev_switch = ssdk_dts_netdev_switch_find_by_netdev(dp->cpu_dp->conduit);
+#else
 	netdev_switch = ssdk_dts_netdev_switch_find_by_netdev(dp->cpu_dp->master);
+#endif
 	if (!netdev_switch)
 		return NOTIFY_DONE;
 
