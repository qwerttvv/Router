# ==================================
# 标题与描述
# ==================================
msgid "Athena LED Controller"
msgstr "雅典娜 LED 控制器"

msgid "JDCloud AX6600 LED Screen Controller (v2.0.0 Multi-Profile Edition)"
msgstr "京东云 AX6600 点阵屏控制 (v2.0.0 多频道版)"

# ==================================
# 板块 1: 基础设置与模式切换
# ==================================
msgid "General Settings"
msgstr "基础设置"

msgid "Enabled"
msgstr "启用"

msgid "Brightness Level"
msgstr "屏幕亮度"

msgid "Adjust screen brightness (0-7)."
msgstr "调节屏幕亮度 (0-7)。"

msgid "Button & Profile Mode"
msgstr "按键与配置模式"

msgid "Single Profile (Button skips to next module)"
msgstr "单频道模式 (按键跳至下一模块)"

msgid "Multi Profile (Button switches to next channel)"
msgstr "多频道模式 (按键切换至下一频道)"

msgid "<b>Single Profile:</b> All modules loop continuously. Button skips current module.<br/><b>Multi Profile:</b> Modules are grouped into channels. Button switches channels."
msgstr "<b>单频道模式：</b> 所有模块在同一列表内循环显示，按键可跳过当前模块。<br/><b>多频道模式：</b> 模块被分组隔离到不同的频道中，按键用于在不同频道间进行切换。"

# ==================================
# 板块 2: 表格布局与模块选项
# ==================================
msgid "Single Profile Layout"
msgstr "单频道模块编排"

msgid "Used ONLY when <b>Single Profile</b> mode is selected. Drag to reorder."
msgstr "仅在选中 <b>单频道模式</b> 时生效。可上下拖拽整行进行排序。"

msgid "Multi Profile Layout"
msgstr "多频道模块编排"

msgid "Used ONLY when <b>Multi Profile</b> mode is selected. Group modules by assigning them to the same channel."
msgstr "仅在选中 <b>多频道模式</b> 时生效。请将模块分配到对应的频道中进行分组。"

msgid "Channel ID"
msgstr "所属频道"

msgid "Channel "
msgstr "频道 "

msgid "Display Module"
msgstr "显示模块"

msgid "Duration (s)"
msgstr "持续时间 (秒)"

# --- 模块带 Emoji 的下拉选项 (完整 27 模块版) ---
msgid "⌚ Time (HH:MM:SS)"
msgstr "⌚ 时间 (时:分:秒)"

msgid "⌚ Time (Blink)"
msgstr "⌚ 时间 (闪烁效果)"

msgid "⌚ Time (Static)"
msgstr "⌚ 时间 (静态显示)"

msgid "📅 Date (MM-DD)"
msgstr "📅 日期 (月-日)"

msgid "📅 Date (YYYY.MM.DD)"
msgstr "📅 日期 (带年份)"

msgid "📅 Week & Time (Cycle)"
msgstr "🗓️ 星期与时间循环"

msgid "📅 Day of Week"
msgstr "🗓️ 仅星期几"

msgid "⛅ Local Weather"
msgstr "⛅ 当地天气"

msgid "💻 CPU Load"
msgstr "💻 CPU 占用率"

msgid "💾 RAM Usage"
msgstr "💾 内存占用率"

msgid "⚙️ System Load"
msgstr "⚙️ 系统负载"

msgid "🌡️ Temperatures"
msgstr "🌡️ 系统温度"

msgid "⏱️ System Uptime"
msgstr "⏱️ 系统运行时间"

msgid "🌐 Realtime Speed (DL/UL)"
msgstr "🌐 实时网速拆分"

msgid "⬇️ Download Speed"
msgstr "⬇️ 实时下载速度"

msgid "⬆️ Upload Speed"
msgstr "⬆️ 实时上传速度"

msgid "📥 Total Downloaded"
msgstr "📥 累计下载流量"

msgid "📤 Total Uploaded"
msgstr "📤 累计上传流量"

msgid "📊 Total Traffic (DL+UL)"
msgstr "📊 累计总流量"

msgid "🔌 NIC Status"
msgstr "🔌 物理网口状态"

msgid "📝 Custom Text"
msgstr "📝 自定义文本"

msgid "🔗 HTTP API"
msgstr "🔗 HTTP API 接口"

msgid "📈 Stock Trend"
msgstr "📈 股票行情趋势"

msgid "🌍 WAN IP"
msgstr "🌍 广域网 IP"

msgid "📱 Online Devices"
msgstr "📱 局域网设备数"

# ==================================
# 板块 3: 网络设置
# ==================================
msgid "Network Settings"
msgstr "网络设置"

msgid "Network Interface"
msgstr "网络接口"

msgid "Interface for traffic monitoring (e.g. br-lan)."
msgstr "用于流量监控的接口 (例如 br-lan)。"

msgid "WAN IP API"
msgstr "WAN IP 查询接口"

msgid "Select a preset or enter custom URL."
msgstr "选择预设或输入自定义 URL。"

# ==================================
# 板块 4: 传感器与天气
# ==================================
msgid "Sensor & Weather"
msgstr "传感器与天气"

msgid "Temperature Sensors"
msgstr "温度传感器"

msgid "Select sensors to cycle through."
msgstr "选择需要轮播显示的传感器。"

msgid "nss-top"
msgstr "NSS-Top"

msgid "nss"
msgstr "NSS"

msgid "wcss-phya0"
msgstr "无线 PHY0"

msgid "wcss-phya1"
msgstr "无线 PHY1"

msgid "cpu"
msgstr "CPU"

msgid "lpass"
msgstr "LPASS"

msgid "ddrss"
msgstr "DDR 内存"

msgid "Weather Source"
msgstr "天气数据源"

msgid "City Name"
msgstr "城市名称"

msgid "Pinyin, English, or 'auto'."
msgstr "请输入拼音、英文，或输入 'auto' 自动定位。"

msgid "Weather Format"
msgstr "天气显示格式"

msgid "Simple (Static Icon + Temp)"
msgstr "简约 (静态图标防抖 + 温度)"

msgid "Full (Rolling Text)"
msgstr "完整 (长文本平滑滚动)"

msgid "Simple mode prevents scrolling and locks position. Full mode rolls long text."
msgstr "简约模式会锁定显示位置并防止滚动。完整模式会平滑滚动显示附带极值的天气长文本。"

msgid "Seniverse API Key"
msgstr "心知天气 API 密钥"

# ==================================
# 板块 5: 自定义内容与 API
# ==================================
msgid "Custom Content & APIs"
msgstr "自定义内容与拓展 API"

msgid "Custom Text (banner)"
msgstr "自定义文本 (banner)"

msgid "Shown when 'banner' is in the profile."
msgstr "当所选频道中包含 'banner' 模块时显示。"

msgid "Stock API URL (stock)"
msgstr "股票 API 地址 (stock)"

msgid "Shown when 'stock' is in the profile."
msgstr "当所选频道中包含 'stock' 模块时显示。"

msgid "HTTP Request URL (http_custom)"
msgstr "HTTP 请求地址 (http_custom)"

msgid "Shown when 'http_custom' is in the profile."
msgstr "当所选频道中包含 'http_custom' 模块时显示。"

msgid "HTTP Cache Time (s)"
msgstr "HTTP 缓存时间 (秒)"

msgid "Cache API results to prevent rate limiting."
msgstr "缓存接口请求结果，防止频率过高被限流封禁。"

msgid "HTTP Max Length"
msgstr "HTTP 最大显示长度"

msgid "Max characters to display (defaults to 15)."
msgstr "最大显示字符数 (默认 15)。如需完整滚动长文本请调大此值。"

# ==================================
# 板块 6: 硬件 LED 状态灯控制
# ==================================
msgid "Hardware LED Switches"
msgstr "硬件 LED 状态灯控制"

msgid "Check the box to <b>Turn OFF (Disable)</b> specific status LEDs on the router."
msgstr "勾选对应选项以<b>永久关闭（熄灭）</b>路由器机身上的特定物理状态指示灯。"

msgid "Disable Clock LED (CPU/Mem)"
msgstr "熄灭【时钟灯】(对应 CPU/内存负载)"

msgid "Disable Medal LED (Internet)"
msgstr "熄灭【勋章灯】(对应 网络连通状态)"

msgid "Disable Upload LED (Arrow Up)"
msgstr "熄灭【上箭头灯】(对应 数据上传指示)"

msgid "Disable Download LED (Arrow Down)"
msgstr "熄灭【下箭头灯】(对应 数据下载指示)"

# ==================================
# 板块 7: 定时休眠
# ==================================
msgid "Scheduled Sleep"
msgstr "定时休眠"

msgid "Enable Scheduled Sleep"
msgstr "启用定时休眠"

msgid "Screen Off Time"
msgstr "屏幕关闭时间"

msgid "HH:MM format (e.g. 23:00)."
msgstr "请输入 HH:MM 格式 (例如 23:00)。"

msgid "Screen On Time"
msgstr "屏幕开启时间"

msgid "HH:MM format (e.g. 07:00)."
msgstr "请输入 HH:MM 格式 (例如 07:00)。"

# ==================================
# 板块 8: 服务控制与状态
# ==================================
msgid "Service Control"
msgstr "服务控制"

msgid "Restart Service"
msgstr "重启服务"

msgid "Force restart the process immediately."
msgstr "保存配置并立即强制重启后台守护进程。"

msgid "Stop Service"
msgstr "停止服务"

msgid "Stop the process (Will restart on reboot if Enabled is checked)."
msgstr "停止进程 (若“启用”被勾选，路由器重启后仍会自动启动)。"

msgid "Running Status"
msgstr "运行状态"

msgid "Collecting data..."
msgstr "正在获取运行状态..."

msgid "RUNNING"
msgstr "运行中"

msgid "NOT RUNNING"
msgstr "未运行"

msgid "Unknown Error"
msgstr "未知错误"

