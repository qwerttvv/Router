msgstr "DDR 内存"

# ==================================
# 极客按键引脚配置
# ==================================
msgid "Physical Button GPIO"
msgstr "物理按键 GPIO 引脚"

msgid "GPIO pin number for the physical screen button. Default is 71 for JDCloud AX6600. Run 'find_button' in SSH to detect if unsure."
msgstr "屏幕切换物理按键的 GPIO 引脚号。雅典娜默认通常为 71。如不确定，可在 SSH 终端执行 find_button 命令进行雷达探测。"