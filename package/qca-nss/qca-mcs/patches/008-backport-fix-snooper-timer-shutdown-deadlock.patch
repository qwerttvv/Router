--- a/mc_snooping.c
+++ b/mc_snooping.c
@@ -636,6 +636,7 @@ int mc_mdb_destroy_by_port(struct mc_str
  */
 static void mc_mdb_destroy(struct mc_mdb_entry *mdb)
 {
+	struct mc_struct *mc = mdb->mc;
 	struct hlist_node *h;
 	struct mc_port_group *pg;
 
@@ -645,7 +646,14 @@ static void mc_mdb_destroy(struct mc_mdb
 	}
 
 	hlist_del_rcu(&mdb->hlist);
+
+	/*
+	 * Avoid AB-BA lock ordering deadlock by releasing the snooper lock
+	 * while synchronously shutting down the MDB entry timer.
+	 */
+	spin_unlock_bh(&mc->lock);
 	timer_delete_sync(&mdb->etimer);
+	spin_lock_bh(&mc->lock);
 
 	if (mdb->flood_ifcnt || mdb->encap_dev_cnt) {
 		mdb->flood_ifcnt = 0;
@@ -2938,11 +2946,17 @@ static int mc_stop(struct mc_struct *mc)
 	spin_lock_bh(&g_mcs_lock);
 	mc_forward_exit();
 	spin_unlock_bh(&g_mcs_lock);
+
+	/*
+	 * Ensure mc_mdb_cleanup() has finished and cannot re-arm the aging
+	 * timer before mc_mdb_flush() destroys all MDB entries.
+	 */
+	timer_delete_sync(&mc->agingtimer);
+
 	mc_mdb_flush(mc);
 	mc_rlist_flush(mc);
 
 	timer_delete_sync(&mc->qtimer);
-	timer_delete_sync(&mc->agingtimer);
 	timer_delete_sync(&mc->rtimer);
 	timer_delete_sync(&mc->evtimer);
 
