From: Julius Bairaktaris <julius@bairaktaris.de>
Subject: [PATCH] frontends: declare in for VXLAN-GPE node establish

ecm_ipv{4,6}_node_establish_and_ref() use a local struct net_device *in in the
VXLAN/VXLAN-GPE branch, but the declaration guard did not include
ECM_INTERFACE_VXLAN_ENABLE. Add it to both IPv4 and IPv6.

Signed-off-by: Julius Bairaktaris <julius@bairaktaris.de>
---
 frontends/cmn/ecm_ipv4.c | 2 +-
 frontends/cmn/ecm_ipv6.c | 2 +-
 2 files changed, 2 insertions(+), 2 deletions(-)

--- a/frontends/cmn/ecm_ipv4.c
+++ b/frontends/cmn/ecm_ipv4.c
@@ -221,7 +221,7 @@ struct ecm_db_node_instance *ecm_ipv4_no
 	struct net_device *local_dev;
 #endif
 
-#if defined(ECM_INTERFACE_MAP_T_ENABLE) || defined(ECM_INTERFACE_GRE_TUN_ENABLE) || defined(ECM_XFRM_ENABLE)
+#if defined(ECM_INTERFACE_VXLAN_ENABLE) || defined(ECM_INTERFACE_MAP_T_ENABLE) || defined(ECM_INTERFACE_GRE_TUN_ENABLE) || defined(ECM_XFRM_ENABLE)
 	struct net_device *in;
 #endif
 
--- a/frontends/cmn/ecm_ipv6.c
+++ b/frontends/cmn/ecm_ipv6.c
@@ -218,7 +218,7 @@ struct ecm_db_node_instance *ecm_ipv6_no
 	struct inet6_dev *ip6_inetdev;
 #endif
 
-#if defined(ECM_INTERFACE_GRE_TUN_ENABLE) || defined(ECM_XFRM_ENABLE)
+#if defined(ECM_INTERFACE_VXLAN_ENABLE) || defined(ECM_INTERFACE_GRE_TUN_ENABLE) || defined(ECM_XFRM_ENABLE)
 	struct net_device *in;
 #endif
 
