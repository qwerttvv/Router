From: Julius Bairaktaris <julius@bairaktaris.de>
Subject: [PATCH] frontends: restore IPv4/IPv6 offload parity

Mirror the working sibling frontend behavior for several IPv4/IPv6 parity
issues in connection sync, non-ported protocol support, AE precedence, and DSA
egress VLAN handling.

Signed-off-by: Julius Bairaktaris <julius@bairaktaris.de>
---
 frontends/cmn/ecm_non_ported_ipv4.c | 1 +
 frontends/cmn/ecm_ported_ipv6.c     | 2 ++
 frontends/nss/ecm_nss_ipv6.c        | 5 ++++-
 frontends/nss/ecm_nss_ported_ipv6.c | 2 +-
 4 files changed, 8 insertions(+), 2 deletions(-)

--- a/frontends/nss/ecm_nss_ipv6.c
+++ b/frontends/nss/ecm_nss_ipv6.c
@@ -321,7 +321,7 @@ static inline void ecm_nss_ipv6_process_
 			 * The amount of data *sent* by the ECM multicast connection 'from' side is the amount the NSS has *received* in the 'flow' direction.
 			 */
 			ecm_db_multicast_connection_data_totals_update(ci, true, sync->flow_rx_byte_count, sync->flow_rx_packet_count);
-			ecm_db_multicast_connection_data_totals_update(ci, true, sync->return_rx_byte_count, sync->return_rx_packet_count);
+			ecm_db_multicast_connection_data_totals_update(ci, false, sync->return_rx_byte_count, sync->return_rx_packet_count);
 			ecm_db_multicast_connection_interface_heirarchy_stats_update(ci, sync->flow_rx_byte_count, sync->flow_rx_packet_count);
 
 			/*
@@ -577,6 +577,9 @@ sync_conntrack:
 			if (reply_pkts != 0) {
 				struct nf_conntrack_l4proto *l4proto __maybe_unused;
 				unsigned int *timeouts;
+
+				set_bit(IPS_SEEN_REPLY_BIT, &ct->status);
+				set_bit(IPS_ASSURED_BIT, &ct->status);
 #if (LINUX_VERSION_CODE < KERNEL_VERSION(4, 19, 0))
 				l4proto = __nf_ct_l4proto_find(AF_INET6, IPPROTO_UDP);
 				timeouts = nf_ct_timeout_lookup(&init_net, ct, l4proto);
--- a/frontends/cmn/ecm_non_ported_ipv4.c
+++ b/frontends/cmn/ecm_non_ported_ipv4.c
@@ -110,6 +110,7 @@ static inline bool ecm_non_ported_ipv4_i
 #if defined(ECM_INTERFACE_PPTP_ENABLE) || defined(ECM_INTERFACE_GRE_TAP_ENABLE) || defined(ECM_INTERFACE_GRE_TUN_ENABLE)
 	case IPPROTO_GRE:
 #endif
+	case IPPROTO_ETHERIP:
 	case IPPROTO_RAW:
 #ifdef ECM_INTERFACE_L2TPV3_ENABLE
 	case IPPROTO_L2TP:
--- a/frontends/cmn/ecm_ported_ipv6.c
+++ b/frontends/cmn/ecm_ported_ipv6.c
@@ -567,6 +567,7 @@ unsigned int ecm_ported_ipv6_process(str
 			 * to the database without accelerating the flow.
 			 */
 			flags &= ~ECM_FRONT_END_ENGINE_FLAG_CAN_ACCEL;
+			flags |= ECM_FRONT_END_ENGINE_FLAG_AE_PRECEDENCE;
 			goto precedence_alloc;
 
 		case ECM_AE_CLASSIFIER_RESULT_DONT_CARE:
@@ -574,6 +575,7 @@ unsigned int ecm_ported_ipv6_process(str
 			 * External module doesn't care about which AE is selected.
 			 * So, allocate one from the AE precedence array.
 			 */
+			flags |= ECM_FRONT_END_ENGINE_FLAG_AE_PRECEDENCE;
 			goto precedence_alloc;
 
 		default:
--- a/frontends/nss/ecm_nss_ported_ipv6.c
+++ b/frontends/nss/ecm_nss_ported_ipv6.c
@@ -915,7 +915,7 @@ static void ecm_nss_ported_ipv6_connecti
 			/*
 			 * Ready to write the DSA VLAN rule
 			 */
-			nircm->vlan_primary_rule.egress_vlan_tag = vlan_value;
+			nircm->vlan_primary_rule.egress_vlan_tag = dsa_vlan_value;
 			nircm->valid_flags |= NSS_IPV6_RULE_CREATE_VLAN_VALID;
 
 			/*
