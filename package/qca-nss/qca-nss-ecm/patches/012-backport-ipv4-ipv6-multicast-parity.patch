From: Julius Bairaktaris <julius@bairaktaris.de>
Subject: [PATCH] frontends: restore IPv4/IPv6 multicast offload parity

Mirror IPv4 multicast frontend behavior in the IPv6 path:

- stop VLAN from-walk fallthrough into the DSA case;
- declare DSA info with the DSA interface type expected by the local API;
- rebuild the IPv6 from-NAT hierarchy with ip_version 6;
- reject a pure-bridge multicast path when the output master is missing.

Signed-off-by: Julius Bairaktaris <julius@bairaktaris.de>
---
 frontends/cmn/ecm_multicast_ipv6.c     | 7 +++++--
 frontends/nss/ecm_nss_multicast_ipv6.c | 3 ++-
 2 files changed, 7 insertions(+), 3 deletions(-)

--- a/frontends/nss/ecm_nss_multicast_ipv6.c
+++ b/frontends/nss/ecm_nss_multicast_ipv6.c
@@ -1014,9 +1014,10 @@ static void ecm_nss_multicast_ipv6_conne
 			rule_invalid = true;
 			DEBUG_TRACE("%px: VLAN - unsupported\n", feci);
 #endif
+			break;
 		case ECM_DB_IFACE_TYPE_DSA:
 #ifdef ECM_INTERFACE_DSA_ENABLE
-			struct ecm_db_interface_info_vlan vlan_info;
+			struct ecm_db_interface_info_dsa dsa_info;
 
 			DEBUG_TRACE("%px: DSA\n", feci);
 			if (interface_type_counts[ECM_DB_IFACE_TYPE_VLAN] > 0) {
--- a/frontends/cmn/ecm_multicast_ipv6.c
+++ b/frontends/cmn/ecm_multicast_ipv6.c
@@ -198,7 +198,7 @@ static void ecm_multicast_ipv6_connectio
 	ecm_db_connection_interfaces_deref(from_list, from_list_first);
 
 	DEBUG_TRACE("%px: Update the 'from NAT' interface heirarchy list\n", ci);
-	from_nat_list_first = ecm_interface_multicast_from_heirarchy_construct(feci, from_nat_list, ip_dest_addr, ip_src_addr_nat, 4, protocol, in_dev_nat, is_routed, in_dev_nat, src_node_addr_nat, dest_node_addr, layer4hdr, NULL);
+	from_nat_list_first = ecm_interface_multicast_from_heirarchy_construct(feci, from_nat_list, ip_dest_addr, ip_src_addr_nat, 6, protocol, in_dev_nat, is_routed, in_dev_nat, src_node_addr_nat, dest_node_addr, layer4hdr, NULL);
 	if (from_nat_list_first == ECM_DB_IFACE_HEIRARCHY_MAX) {
 		goto ecm_multicast_ipv6_retry_regen;
 	}
@@ -700,7 +700,10 @@ unsigned int ecm_multicast_ipv6_connecti
 	 * interface list
 	 */
 	out_dev_master =  ecm_interface_get_and_hold_dev_master(out_dev);
-	DEBUG_ASSERT(out_dev_master, "Expected a master\n");
+	if (!out_dev_master) {
+		DEBUG_WARN("%s is not master device\n", out_dev ? out_dev->name : NULL);
+		goto done;
+	}
 	mc_if_cnt = mc_bridge_ipv6_get_if(out_dev_master, &origin6, &group6,
 			ECM_DB_MULTICAST_IF_MAX, mc_dest_if, mcuc_addr);
 	if (mc_if_cnt <= 0) {
