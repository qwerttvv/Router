From 6032075f347b6bc7d56f92bf6dcd6701c39b2c59 Mon Sep 17 00:00:00 2001
From: Suhas N Bhargav <sbhargav@qti.qualcomm.com>
Date: Wed, 24 Dec 2025 14:25:59 +0530
Subject: [PATCH] qca-nss-ecm: reject unsupported OVS multicast flows

Reject multicast packets over OVS bridge to the Linux slow path when the
selected frontend does not support OVS multicast offload. Also decelerate
existing SFE multicast rules when routed multicast destination lists include
OVS bridge ports.

The upstream change also adjusts ecm_interface_linux_mcs_bridge_get_if(), but
that helper is not present in this source line, so only the matching frontend
and multicast handling pieces are carried here.

Change-Id: I11381bbdb11f2505ceab364fdb6cdf5292a912b9
Signed-off-by: Suhas N Bhargav <sbhargav@qti.qualcomm.com>
---
 frontends/cmn/ecm_ipv4.c                | 14 ++++++++++++++
 frontends/cmn/ecm_ipv6.c                | 16 +++++++++++++++-
 frontends/cmn/ecm_multicast_ipv4.c      | 10 ++++++++++
 frontends/cmn/ecm_multicast_ipv6.c      | 12 +++++++++++-
 frontends/ecm_front_end_common.c        | 18 ++++++++++++++++++
 frontends/include/ecm_front_end_types.h |  1 +
 frontends/sfe/ecm_sfe_multicast_ipv4.c  | 23 +++++++++++++++++++++++
 frontends/sfe/ecm_sfe_multicast_ipv6.c  | 23 +++++++++++++++++++++++
 8 files changed, 114 insertions(+), 3 deletions(-)

--- a/frontends/include/ecm_front_end_types.h
+++ b/frontends/include/ecm_front_end_types.h
@@ -147,6 +147,7 @@ enum ecm_fe_feature {
 	ECM_FE_FEATURE_OVS_BRIDGE	= (1 << 11),
 	ECM_FE_FEATURE_OVS_VLAN		= (1 << 12),
 	ECM_FE_FEATURE_PPE		= (1 << 13),
+	ECM_FE_FEATURE_OVS_MULTICAST	= (1 << 14),
 };
 
 /*
--- a/frontends/ecm_front_end_common.c
+++ b/frontends/ecm_front_end_common.c
@@ -167,6 +167,9 @@ uint32_t ecm_fe_feature_list[ECM_FRONT_E
 	/* SFE type */
 	ECM_FE_FEATURE_SFE | ECM_FE_FEATURE_NON_PORTED | ECM_FE_FEATURE_CONN_LIMIT |
 	ECM_FE_FEATURE_OVS_BRIDGE | ECM_FE_FEATURE_OVS_VLAN | ECM_FE_FEATURE_BRIDGE |
+#ifndef ECM_MCAST_LINUX_SNOOPER_SUPPORT
+	ECM_FE_FEATURE_OVS_MULTICAST |
+#endif
 	ECM_FE_FEATURE_BONDING | ECM_FE_FEATURE_SRC_IF_CHECK | ECM_FE_FEATURE_MULTICAST,
 
 	/* PPE */
@@ -183,6 +186,9 @@ uint32_t ecm_fe_feature_list[ECM_FRONT_E
 	ECM_FE_FEATURE_MULTICAST | ECM_FE_FEATURE_BONDING | ECM_FE_FEATURE_IGS |
 	ECM_FE_FEATURE_SRC_IF_CHECK | ECM_FE_FEATURE_CONN_LIMIT |
 	ECM_FE_FEATURE_DSCP_ACTION | ECM_FE_FEATURE_XFRM | ECM_FE_FEATURE_OVS_BRIDGE |
+#ifndef ECM_MCAST_LINUX_SNOOPER_SUPPORT
+	ECM_FE_FEATURE_OVS_MULTICAST |
+#endif
 	ECM_FE_FEATURE_OVS_VLAN,
 
 	/*
@@ -192,10 +198,16 @@ uint32_t ecm_fe_feature_list[ECM_FRONT_E
 #ifndef ECM_PPE_SOURCE_INTERFACE_CHECK_ENABLE
 	ECM_FE_FEATURE_SFE | ECM_FE_FEATURE_NON_PORTED | ECM_FE_FEATURE_CONN_LIMIT |
 	ECM_FE_FEATURE_OVS_BRIDGE | ECM_FE_FEATURE_OVS_VLAN | ECM_FE_FEATURE_BRIDGE |
+#ifndef ECM_MCAST_LINUX_SNOOPER_SUPPORT
+	ECM_FE_FEATURE_OVS_MULTICAST |
+#endif
 	ECM_FE_FEATURE_BONDING | ECM_FE_FEATURE_PPE | ECM_FE_FEATURE_MULTICAST,
 #else
 	ECM_FE_FEATURE_SFE | ECM_FE_FEATURE_NON_PORTED | ECM_FE_FEATURE_CONN_LIMIT |
 	ECM_FE_FEATURE_OVS_BRIDGE | ECM_FE_FEATURE_OVS_VLAN | ECM_FE_FEATURE_BRIDGE |
+#ifndef ECM_MCAST_LINUX_SNOOPER_SUPPORT
+	ECM_FE_FEATURE_OVS_MULTICAST |
+#endif
 	ECM_FE_FEATURE_BONDING | ECM_FE_FEATURE_PPE | ECM_FE_FEATURE_MULTICAST | ECM_FE_FEATURE_SRC_IF_CHECK,
 #endif
 
@@ -205,10 +217,16 @@ uint32_t ecm_fe_feature_list[ECM_FRONT_E
 #ifndef ECM_PPE_SOURCE_INTERFACE_CHECK_ENABLE
 	ECM_FE_FEATURE_SFE | ECM_FE_FEATURE_NON_PORTED | ECM_FE_FEATURE_CONN_LIMIT |
 	ECM_FE_FEATURE_OVS_BRIDGE | ECM_FE_FEATURE_OVS_VLAN | ECM_FE_FEATURE_BRIDGE |
+#ifndef ECM_MCAST_LINUX_SNOOPER_SUPPORT
+	ECM_FE_FEATURE_OVS_MULTICAST |
+#endif
 	ECM_FE_FEATURE_BONDING | ECM_FE_FEATURE_PPE | ECM_FE_FEATURE_MULTICAST,
 #else
 	ECM_FE_FEATURE_SFE | ECM_FE_FEATURE_NON_PORTED | ECM_FE_FEATURE_CONN_LIMIT |
 	ECM_FE_FEATURE_OVS_BRIDGE | ECM_FE_FEATURE_OVS_VLAN | ECM_FE_FEATURE_BRIDGE |
+#ifndef ECM_MCAST_LINUX_SNOOPER_SUPPORT
+	ECM_FE_FEATURE_OVS_MULTICAST |
+#endif
 	ECM_FE_FEATURE_BONDING | ECM_FE_FEATURE_PPE | ECM_FE_FEATURE_MULTICAST | ECM_FE_FEATURE_SRC_IF_CHECK,
 #endif
 };
--- a/frontends/cmn/ecm_ipv4.c
+++ b/frontends/cmn/ecm_ipv4.c
@@ -1322,6 +1322,15 @@ vxlan_done:
 			return NF_ACCEPT;
 		}
 
+#ifdef ECM_INTERFACE_OVS_BRIDGE_ENABLE
+		if (!ecm_front_end_is_feature_supported(ECM_FE_FEATURE_OVS_MULTICAST)) {
+			if (ovsmgr_is_ovs_master(in_dev) || ovsmgr_is_ovs_master(out_dev)) {
+				DEBUG_WARN("OVS MCAST offload is not supported; in = %s, out = %s\n", in_dev->name, out_dev->name);
+				ecm_stats_v4_inc(ECM_STATS_V4_EXCEPTION_CMN, ECM_STATS_V4_EXCEPTION_MCAST_NOT_SUPPORTED);
+				return NF_ACCEPT;
+			}
+		}
+#endif
 		DEBUG_TRACE("%px: CMN Multicast, Processing\n", skb);
 		return ecm_multicast_ipv4_connection_process(out_dev, in_dev, src_node_addr, dest_node_addr,
 									can_accel, is_routed, skb, &ip_hdr, ct, sender,
@@ -2219,6 +2228,11 @@ unsigned int ecm_ipv4_ovs_dp_process(str
 			DEBUG_TRACE("Frontend does not support mcast, ignoring: %px\n", skb);
 			return 1;
 		}
+
+		if (!ecm_front_end_is_feature_supported(ECM_FE_FEATURE_OVS_MULTICAST)) {
+			DEBUG_WARN("Pure IPv4 bridge OVS Mcast offload not supported\n");
+			return 1;
+		}
 	}
 
 	if (skb->protocol != ntohs(ETH_P_IP)) {
--- a/frontends/cmn/ecm_ipv6.c
+++ b/frontends/cmn/ecm_ipv6.c
@@ -1311,6 +1311,15 @@ vxlan_done:
 			return NF_ACCEPT;
 		}
 
+#ifdef ECM_INTERFACE_OVS_BRIDGE_ENABLE
+		if (!ecm_front_end_is_feature_supported(ECM_FE_FEATURE_OVS_MULTICAST)) {
+			if (ovsmgr_is_ovs_master(in_dev) || ovsmgr_is_ovs_master(out_dev)) {
+				DEBUG_WARN("OVS MCAST offload is not supported; in = %s, out = %s\n", in_dev->name, out_dev->name);
+				ecm_stats_v6_inc(ECM_STATS_V6_EXCEPTION_CMN, ECM_STATS_V6_EXCEPTION_MCAST_NOT_SUPPORTED);
+				return NF_ACCEPT;
+			}
+		}
+#endif
 		return ecm_multicast_ipv6_connection_process(out_dev, in_dev, src_node_addr, dest_node_addr,
 				can_accel, is_routed, skb, &ip_hdr, ct, sender,
 				&orig_tuple, &reply_tuple);
@@ -2330,7 +2339,12 @@ unsigned int ecm_ipv6_ovs_dp_process(str
 	 */
 	if (skb->pkt_type == PACKET_MULTICAST) {
 		if (!ecm_front_end_is_feature_supported(ECM_FE_FEATURE_MULTICAST)) {
-			DEBUG_TRACE("Broadcast, ignoring: %px\n", skb);
+			DEBUG_TRACE("Frontend does not support mcast, ignoring: %px\n", skb);
+			return 1;
+		}
+
+		if (!ecm_front_end_is_feature_supported(ECM_FE_FEATURE_OVS_MULTICAST)) {
+			DEBUG_WARN("Pure IPv6 bridge OVS Mcast offload not supported\n");
 			return 1;
 		}
 	}
--- a/frontends/cmn/ecm_multicast_ipv4.c
+++ b/frontends/cmn/ecm_multicast_ipv4.c
@@ -655,6 +655,16 @@ unsigned int ecm_multicast_ipv4_connecti
 				if_cnt, &orig_tuple->src.u3.ip, &orig_tuple->dst.u3.ip);
 			return NF_ACCEPT;
 		}
+
+#if defined (ECM_INTERFACE_OVS_BRIDGE_ENABLE) && defined(ECM_MCAST_LINUX_SNOOPER_SUPPORT)
+		/*
+		 * If the MFC table has OVS ports in its list, ECM cannot offload.
+		 */
+		if (ecm_interface_multicast_check_for_ovs_br_dev(dst_dev, (uint8_t)if_cnt)) {
+			DEBUG_WARN("MFC routing table containing ovs bridge ports cannot be offloaded\n");
+			return NF_ACCEPT;
+		}
+#endif
 	}
 
 	/*
--- a/frontends/cmn/ecm_multicast_ipv6.c
+++ b/frontends/cmn/ecm_multicast_ipv6.c
@@ -529,7 +529,7 @@ unsigned int ecm_multicast_ipv6_connecti
 	ip_addr_t match_addr;
 	struct ecm_classifier_instance *assignments[ECM_CLASSIFIER_TYPES];
 	int aci_index;
-	int32_t mc_if_cnt;
+	int mc_if_cnt;
 	int assignment_count;
 	ecm_db_timer_group_t ci_orig_timer_group;
 	struct ecm_classifier_process_response prevalent_pr;
@@ -628,6 +628,16 @@ unsigned int ecm_multicast_ipv6_connecti
 			DEBUG_WARN("Not found a valid vif count %d\n", mc_if_cnt);
 			return NF_ACCEPT;
 		}
+
+#if defined (ECM_INTERFACE_OVS_BRIDGE_ENABLE) && defined(ECM_MCAST_LINUX_SNOOPER_SUPPORT)
+		/*
+		 * If the MFC table has OVS ports in its list, ECM cannot offload.
+		 */
+		if (ecm_interface_multicast_check_for_ovs_br_dev(mc_dest_if, (uint8_t)mc_if_cnt)) {
+			DEBUG_WARN("MFC routing table containing ovs bridge ports cannot be offloaded\n");
+			return NF_ACCEPT;
+		}
+#endif
 	}
 
 	/*
--- a/frontends/sfe/ecm_sfe_multicast_ipv4.c
+++ b/frontends/sfe/ecm_sfe_multicast_ipv4.c
@@ -2573,6 +2573,19 @@ process_ipmr_entry:
 			}
 
 			/*
+			 * If list of multicast destination ifindexes contain any OVS bridge port,
+			 * decelerate that connection.
+			 */
+#if defined (ECM_INTERFACE_OVS_BRIDGE_ENABLE) && defined(ECM_MCAST_LINUX_SNOOPER_SUPPORT)
+			if (ecm_interface_multicast_check_for_ovs_br_dev(dst_dev, (uint8_t)dst_if_cnt)) {
+				DEBUG_WARN("iface list has ovs ports; Decelerate Mcast rules\n");
+				feci->decelerate(feci);
+				ecm_front_end_connection_deref(feci);
+				goto find_next_tuple;
+			}
+#endif
+
+			/*
 			 * Update should be allowed for the connection only if 'brdev' is part of ipmr destination interface list.
 			 */
 			for (i = 0; i < dst_if_cnt; i++) {
@@ -2935,6 +2948,16 @@ static void ecm_sfe_mfc_update_event_cal
 		return;
 	}
 
+	/*
+	 * If list of multicast destination ifindexes contain any OVS bridge port,
+	 * trigger an MFC_EVENT_DELETE op.
+	 */
+#if defined (ECM_INTERFACE_OVS_BRIDGE_ENABLE) && defined(ECM_MCAST_LINUX_SNOOPER_SUPPORT)
+	if (ecm_interface_multicast_check_for_ovs_br_dev(to_dev_idx, (uint8_t)max_to_dev)) {
+		DEBUG_WARN("MFC_EVENT: iface list has ovs ports; Decelerate Mcast rules\n");
+		op = IPMR_MFC_EVENT_DELETE;
+	}
+#endif
 	switch (op) {
 	case IPMR_MFC_EVENT_UPDATE:
 	{
--- a/frontends/sfe/ecm_sfe_multicast_ipv6.c
+++ b/frontends/sfe/ecm_sfe_multicast_ipv6.c
@@ -2586,6 +2586,19 @@ process_ipmr_entry:
 			}
 
 			/*
+			 * If list of multicast destination ifindexes contain any OVS bridge port,
+			 * decelerate that connection.
+			 */
+#if defined (ECM_INTERFACE_OVS_BRIDGE_ENABLE) && defined(ECM_MCAST_LINUX_SNOOPER_SUPPORT)
+			if (ecm_interface_multicast_check_for_ovs_br_dev(dst_dev, (uint8_t)dst_if_cnt)) {
+				DEBUG_WARN("iface list has ovs ports; Decelerate Mcast rules\n");
+				feci->decelerate(feci);
+				ecm_front_end_connection_deref(feci);
+				goto find_next_tuple;
+			}
+#endif
+
+			/*
 			 * Update should be allowed for the connection only if 'brdev' is part of ipmr destination interface list.
 			 */
 			for (i = 0; i < dst_if_cnt; i++) {
@@ -2920,6 +2933,16 @@ static void ecm_sfe_multicast_ipv6_mfc_u
 		return;
 	}
 
+	/*
+	 * If list of multicast destination ifindexes contain any OVS bridge port,
+	 * trigger an MFC_EVENT_DELETE op.
+	 */
+#if defined (ECM_INTERFACE_OVS_BRIDGE_ENABLE) && defined(ECM_MCAST_LINUX_SNOOPER_SUPPORT)
+	if (ecm_interface_multicast_check_for_ovs_br_dev(to_dev_idx, (uint8_t)max_to_dev)) {
+		DEBUG_WARN("MFC_EVENT: iface list has ovs ports; Decelerate Mcast rules\n");
+		op = IP6MR_MFC_EVENT_DELETE;
+	}
+#endif
 	switch (op) {
 	case IP6MR_MFC_EVENT_UPDATE:
 	{
