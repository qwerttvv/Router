frontends/nss: respect the bridge port's VLAN tagging for VLAN-over-bridge

The NSS rule create programs (tpid << 16 | vid) as the ingress/egress
VLAN tag for every VLAN interface found in the connection's interface
hierarchy. For a VLAN upper of a VLAN-filtering bridge (br0.X over a
bridge with bridge-vlan configuration - the standard OpenWrt way to
route between VLAN subnets) that is wrong whenever the underlying
bridge port carries the VLAN untagged (pvid/untagged member): the
firmware then requires tagged ingress - dropping every real frame of
the flow's return direction - and emits tagged egress that the peer
host discards. In practice any routed flow into such a network
black-holes a few packets after acceleration kicks in, while the
same flow works on the host path.

Add ecm_interface_bridge_vlan_wire_tagged(): for a VLAN device stacked
on a VLAN-filtering bridge, resolve the bridge port from the same
interface hierarchy and read the port's per-VLAN flags. Untagged/pvid
membership keeps the tag out of the rule (the wire is untagged);
tagged membership programs the tag as before; unresolvable membership
(port not a member - misconfiguration or stale hierarchy) and
asymmetric pvid/untagged memberships (not expressible in the rule's
one-format-per-side model) refuse acceleration so the flow stays on
the always-correct host path. Plain VLAN-over-ethernet (and
non-filtering bridges) are unaffected: the tag stays on the wire.

Applied to the ported and non-ported frontends, IPv4 and IPv6 alike.

Signed-off-by: Julius Bairaktaris <julius@bairaktaris.de>

--- a/ecm_interface.c
+++ b/ecm_interface.c
@@ -375,6 +375,118 @@ struct net_device *ecm_interface_get_and
 }
 EXPORT_SYMBOL(ecm_interface_get_and_hold_dev_master);
 
+/*
+ * ecm_interface_bridge_vlan_wire_tagged()
+ *	Whether frames of a VLAN device stacked on a bridge appear tagged on
+ *	the wire of the underlying bridge port in the given interface hierarchy.
+ *
+ *	On a VLAN-filtering bridge the bridge port's per-VLAN configuration -
+ *	not the VLAN header of the upper device - decides the on-wire format:
+ *	an untagged/pvid member carries this VLAN untagged. An acceleration
+ *	rule programmed with the upper device's tag would make the firmware
+ *	require tagged ingress (dropping every real frame of the flow) and
+ *	emit tagged egress (dropped by the peer).
+ *
+ *	Returns 1 when the tag is on the wire (program it into the rule),
+ *	0 when the wire is untagged for this VLAN (keep the tag out of the
+ *	rule), -1 when the on-wire format cannot be determined or cannot be
+ *	expressed in the rule (caller must not accelerate). VLAN devices not
+ *	stacked on a VLAN-filtering bridge always return 1 (plain 8021q
+ *	semantics, tag on the wire).
+ */
+int ecm_interface_bridge_vlan_wire_tagged(struct ecm_db_iface_instance *vlan_ii,
+					  struct ecm_db_iface_instance *ifaces[],
+					  int32_t first)
+{
+	struct net_device *vlan_dev;
+	struct net_device *real_dev;
+	struct net_device *port_dev = NULL;
+	struct bridge_vlan_info vinfo;
+	uint16_t vid;
+	int32_t i;
+	int ret;
+
+	vlan_dev = dev_get_by_index(&init_net, ecm_db_iface_interface_identifier_get(vlan_ii));
+	if (!vlan_dev) {
+		DEBUG_WARN("%px: no net device behind VLAN interface instance\n", vlan_ii);
+		return -1;
+	}
+
+	if (!is_vlan_dev(vlan_dev)) {
+		DEBUG_WARN("%px: %s is not a VLAN device\n", vlan_ii, vlan_dev->name);
+		dev_put(vlan_dev);
+		return -1;
+	}
+
+	real_dev = vlan_dev_real_dev(vlan_dev);
+	vid = vlan_dev_vlan_id(vlan_dev);
+
+	if (!netif_is_bridge_master(real_dev) || !br_vlan_enabled(real_dev)) {
+		dev_put(vlan_dev);
+		return 1;
+	}
+
+	/*
+	 * Find the bridge port this hierarchy runs through.
+	 */
+	rcu_read_lock();
+	for (i = first; i < ECM_DB_IFACE_HEIRARCHY_MAX; i++) {
+		struct net_device *dev;
+
+		dev = dev_get_by_index(&init_net, ecm_db_iface_interface_identifier_get(ifaces[i]));
+		if (!dev) {
+			continue;
+		}
+
+		if (netif_is_bridge_port(dev) &&
+		    netdev_master_upper_dev_get_rcu(dev) == real_dev) {
+			port_dev = dev;
+			break;
+		}
+		dev_put(dev);
+	}
+
+	if (!port_dev) {
+		rcu_read_unlock();
+		DEBUG_WARN("%px: no port of bridge %s in the interface hierarchy of VLAN %s\n",
+			   vlan_ii, real_dev->name, vlan_dev->name);
+		dev_put(vlan_dev);
+		return -1;
+	}
+
+	if (br_vlan_get_info_rcu(port_dev, vid, &vinfo)) {
+		/*
+		 * The port is not a member of this VLAN: misconfiguration or
+		 * a stale hierarchy - never accelerate on guesses.
+		 */
+		DEBUG_WARN("%px: %s is not a member of VLAN %u on %s\n",
+			   vlan_ii, port_dev->name, vid, real_dev->name);
+		ret = -1;
+	} else {
+		bool pvid = !!(vinfo.flags & BRIDGE_VLAN_INFO_PVID);
+		bool untagged = !!(vinfo.flags & BRIDGE_VLAN_INFO_UNTAGGED);
+
+		if (pvid != untagged) {
+			/*
+			 * Ingress and egress wire formats differ; the rule
+			 * carries one format per side for both directions,
+			 * so this membership cannot be expressed.
+			 */
+			DEBUG_WARN("%px: asymmetric pvid/untagged membership of VLAN %u on %s - not accelerating\n",
+				   vlan_ii, vid, port_dev->name);
+			ret = -1;
+		} else {
+			ret = !untagged;
+		}
+	}
+
+	rcu_read_unlock();
+	dev_put(port_dev);
+	dev_put(vlan_dev);
+	return ret;
+}
+EXPORT_SYMBOL(ecm_interface_bridge_vlan_wire_tagged);
+
