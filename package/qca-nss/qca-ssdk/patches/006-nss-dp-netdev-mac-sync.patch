+static bool ssdk_nss_dp_netdev_check(struct net_device *dev)
+{
+	struct device_node *np = NULL;
+
+	if (!dev || !dev->dev.parent)
+		return false;
+
+	np = dev->dev.parent->of_node;
+
+	return np && of_device_is_compatible(np, "qcom,nss-dp");
+}
+
+static bool ssdk_netdev_switch_init_required(struct net_device *dev)
+{
+	if (!dev || dev->type != ARPHRD_ETHER ||
+	    (dev->priv_flags & IFF_802_1Q_VLAN))
+		return false;
+
+	if (strstr(dev->name, "eth"))
+		return true;
+
+	return ssdk_nss_dp_netdev_check(dev);
+}
+
+static void ssdk_netdev_refresh_mac_sw_sync(struct net_device *dev)
+{
+#ifdef HPPE
+	struct qca_phy_priv *priv = ssdk_phy_priv_data_get(0);
+
+	if (!ssdk_nss_dp_netdev_check(dev) || !priv)
+		return;
+
+	if (!netif_running(dev) || !netif_carrier_ok(dev))
+		return;
+
+	if (!priv->link_polling_required || ssdk_is_emulation(priv->device_id))
+		return;
+
+	if (_ssdk_mac_sw_sync_chip_check(priv) != SW_OK)
+		return;
+
+	mod_delayed_work(system_wq, &priv->mac_sw_sync_dwork,
+			 msecs_to_jiffies(QCA_MAC_SW_SYNC_WORK_DELAY));
+#endif
+}
+
