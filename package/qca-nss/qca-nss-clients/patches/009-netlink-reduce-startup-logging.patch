 #define NSS_NL_DEBUG_LVL_ERROR 1
 #define NSS_NL_DEBUG_LVL_WARN 2
 #define NSS_NL_DEBUG_LVL_INFO 3
@@ -71,7 +73,19 @@
 /*
  * debug message for module init and exit
  */
-#define nss_nl_info_always(s, ...) printk(KERN_INFO"%s[%d]:" s, __func__, __LINE__, ##__VA_ARGS__)
+static inline bool nss_nl_is_startup_noise(const char *fmt)
+{
+	return strstarts(fmt, "Init NSS netlink ") ||
+		strstarts(fmt, "Exit NSS netlink ") ||
+		strstarts(fmt, "Uninitiallizing the NSS netlink ") ||
+		strstarts(fmt, "All active tunnels destroyed");
+}
+
+#define nss_nl_info_always(s, ...) do {	\
+	if (!nss_nl_is_startup_noise(s)) {	\
+		printk(KERN_INFO "%s[%d]:" s, __func__, __LINE__, ##__VA_ARGS__);	\
+	}	\
+} while (0)
 
 
