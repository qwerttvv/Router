act_nssmirred-fix-action-list-corruption-on-release

Signed-off-by: Julius Bairaktaris <julius@bairaktaris.de>

--- a/nss_qdisc/igs/nss_mirred.c
+++ b/nss_qdisc/igs/nss_mirred.c
@@ -43,9 +43,24 @@ static void nss_mirred_release(struct tc
 	struct net_device *dev = rcu_dereference_protected(act->tcfm_dev, 1);
 	struct nss_ifb_info *ifb_info = nss_ifb_find_dev(dev);
 
+	/*
+	 * Unlink the action from the nss mirred action list FIRST and
+	 * unconditionally. The action is freed by the tc core after this
+	 * callback; returning early (e.g. when the IFB was unregistered
+	 * before the action) used to leave the freed action linked in the
+	 * list and poison it for the next list_add. list_del_init() keeps
+	 * the entry self-consistent if this races a repeated release.
+	 */
+	spin_lock_bh(&nss_mirred_list_lock);
+	if (!list_empty(&act->tcfm_list)) {
+		list_del_init(&act->tcfm_list);
+	}
+	spin_unlock_bh(&nss_mirred_list_lock);
+
 	if (!ifb_info) {
-		nss_igs_error("IFB device %s not found in the linked list \n", dev->name);
-		return;
+		nss_igs_error("IFB device %s not found in the linked list \n",
+				dev ? dev->name : "(null)");
+		goto put_dev;
 	}
 
 	/*
@@ -59,12 +74,7 @@ static void nss_mirred_release(struct tc
 		nss_igs_error("Error in sending IFB CLEAR configure message\n");
 	}
 
-	/*
-	 * Delete the nss mirred action list.
-	 */
-	spin_lock_bh(&nss_mirred_list_lock);
-	list_del(&act->tcfm_list);
-	spin_unlock_bh(&nss_mirred_list_lock);
+put_dev:
 	if (dev) {
 		dev_put(dev);
 	}
@@ -248,6 +258,14 @@ static int nss_mirred_init(struct net *n
 	}
 
 	act = nss_mirred_get(*tc_act);
+	if (!ret) {
+		/*
+		 * Freshly created action: make the list entry a valid
+		 * empty node so the (guarded) add and delete below stay
+		 * balanced on every path.
+		 */
+		INIT_LIST_HEAD(&act->tcfm_list);
+	}
 #endif
 	/*
 	 * Fill up the nss mirred tc parameters to
@@ -262,9 +280,12 @@ static int nss_mirred_init(struct net *n
 
 	/*
 	 * Add the new action instance to the nss mirred action list.
+	 * An existing action (tc replace path) is already linked.
 	 */
 	spin_lock_bh(&nss_mirred_list_lock);
-	list_add(&act->tcfm_list, &nss_mirred_list);
+	if (list_empty(&act->tcfm_list)) {
+		list_add(&act->tcfm_list, &nss_mirred_list);
+	}
 	spin_unlock_bh(&nss_mirred_list_lock);
 #if (LINUX_VERSION_CODE < KERNEL_VERSION(5, 4, 0))
 	tcf_hash_insert(tc_act);
