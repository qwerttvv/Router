 {
 	int error,ret;
 
+	if (!nss_nlwifili_wifi_device_available()) {
+		nss_nl_info("ath11k device is unavailable; skipping wifili family\n");
+		return true;
+	}
+
 	nss_nl_info_always("Init NSS netlink wifili handler\n");
 
+	if (!nss_wifili_get_context()) {
+		nss_nl_info("wifili NSS context is unavailable; skipping wifili family\n");
+		return true;
+	}
+
 	/*
 	 * register NETLINK ops with the family
 	 */
@@ -148,6 +204,7 @@ bool nss_nlwifili_init(void)
 		return false;
 	}
 
+	nss_nlwifili_registered = true;
 	return true;
 }
 
@@ -159,6 +216,10 @@ bool nss_nlwifili_exit(void)
 {
 	int error;
 
+	if (!nss_nlwifili_registered) {
+		return true;
+	}
+
 	nss_nl_info_always("Exit NSS netlink wifili handler\n");
 
 	/*
@@ -175,5 +236,6 @@ bool nss_nlwifili_exit(void)
 		return false;
 	}
 
+	nss_nlwifili_registered = false;
 	return true;
 }
