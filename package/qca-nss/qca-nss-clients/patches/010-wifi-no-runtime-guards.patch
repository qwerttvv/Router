--- a/netlink/nss_nlwifili.c
+++ b/netlink/nss_nlwifili.c
@@ -28,6 +28,8 @@
 #include <linux/version.h>
 #include <linux/vmalloc.h>
 #include <linux/notifier.h>
+#include <linux/of.h>
+#include <linux/pci.h>
 
 #include <net/genetlink.h>
 #include <net/sock.h>
@@ -87,6 +89,50 @@ static struct notifier_block nss_wifili_
 	.notifier_call = nss_nlwifili_process_notify,
 };
 
+static bool nss_nlwifili_registered;
+
+static bool nss_nlwifili_of_node_available(const char *compatible)
+{
+#ifdef CONFIG_OF
+	struct device_node *np;
+
+	for_each_compatible_node(np, NULL, compatible) {
+		if (of_device_is_available(np)) {
+			of_node_put(np);
+			return true;
+		}
+	}
+#else
+	(void)compatible;
+#endif
+
+	return false;
+}
+
+static bool nss_nlwifili_pci_device_available(void)
+{
+#if IS_ENABLED(CONFIG_PCI)
+	struct pci_dev *pdev;
+
+	pdev = pci_get_device(0x17cb, 0x1104, NULL);
+	if (pdev) {
+		pci_dev_put(pdev);
+		return true;
+	}
+#endif
+
+	return false;
+}
+
+static bool nss_nlwifili_wifi_device_available(void)
+{
+	return nss_nlwifili_of_node_available("qcom,ipq5018-wifi") ||
+		nss_nlwifili_of_node_available("qcom,ipq6018-wifi") ||
+		nss_nlwifili_of_node_available("qcom,ipq8074-wifi") ||
+		nss_nlwifili_of_node_available("qcom,qcn6122-wifi") ||
+		nss_nlwifili_of_node_available("pci17cb,1104") ||
+		nss_nlwifili_pci_device_available();
+}
 /*
  * nss_nlwifili_ops_get_stats()
