nss_qdisc-guard-stats-attach-detach-against-noop-root

Signed-off-by: Julius Bairaktaris <julius@bairaktaris.de>

--- a/nss_qdisc/nss_qdisc_stats.c
+++ b/nss_qdisc/nss_qdisc_stats.c
@@ -645,6 +645,16 @@ void nss_qdisc_stats_qdisc_attach(struct
 		return;
 	}
 
+	/*
+	 * During tree teardown the kernel points the device root at
+	 * noop_qdisc before destroying the old hierarchy. noop_qdisc has no
+	 * private area, so it must not be passed to qdisc_priv(); the stats
+	 * hash table is freed along with the real root qdisc anyway.
+	 */
+	if (rqdisc == &noop_qdisc) {
+		return;
+	}
+
 	rnq = qdisc_priv(rqdisc);
 	if (!rnq || !rnq->stats_wq) {
 		nss_qdisc_warning(" Error, stats wq should be initialized by now for root qdisc:%x\n", rnq?rnq->qos_tag:0);
@@ -678,6 +688,16 @@ void nss_qdisc_stats_qdisc_detach(struct
 		return;
 	}
 
+	/*
+	 * During tree teardown the kernel points the device root at
+	 * noop_qdisc before destroying the old hierarchy. noop_qdisc has no
+	 * private area, so it must not be passed to qdisc_priv(); the stats
+	 * hash table is freed along with the real root qdisc anyway.
+	 */
+	if (rqdisc == &noop_qdisc) {
+		return;
+	}
+
 	rnq = qdisc_priv(rqdisc);
 	if (!rnq || !rnq->stats_wq) {
 		nss_qdisc_warning(" Error, stats wq should be initialized by now for root qdisc:%x\n", rnq?rnq->qos_tag:0);
