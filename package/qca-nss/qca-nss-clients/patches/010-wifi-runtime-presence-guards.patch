 	.notifier_call = nss_nlwifili_process_notify,
 };
 
+static bool nss_nlwifili_registered;
+
+static bool nss_nlwifili_path_exists(const char *name)
+{
+	struct path path;
+
+	if (kern_path(name, LOOKUP_FOLLOW, &path)) {
+		return false;
+	}
+
+	path_put(&path);
+	return true;
+}
+
+static bool nss_nlwifili_wifi_runtime_available(void)
+{
+	return nss_nlwifili_path_exists("/sys/module/ath11k/parameters/nss_offload")
+		|| nss_nlwifili_path_exists("/sys/kernel/debug/ath11k");
+}
+
 /*
  * nss_nlwifili_ops_get_stats()
  *	get stats handler
@@ -127,8 +148,18 @@ bool nss_nlwifili_init(void)
 {
 	int error,ret;
 
+	if (!nss_nlwifili_wifi_runtime_available()) {
+		printk(KERN_INFO "qca-nss-netlink: no Wi-Fi runtime detected; skipping wifili family\n");
+		return true;
+	}
+
 	nss_nl_info_always("Init NSS netlink wifili handler\n");
 
+	if (!nss_wifili_get_context()) {
+		printk(KERN_INFO "qca-nss-netlink: no Wi-Fi NSS context detected; skipping wifili family\n");
+		return true;
+	}
+
 	/*
 	 * register NETLINK ops with the family
 	 */
@@ -148,6 +179,7 @@ bool nss_nlwifili_init(void)
 		return false;
 	}
 
+	nss_nlwifili_registered = true;
 	return true;
 }
 
@@ -159,6 +191,10 @@ bool nss_nlwifili_exit(void)
 {
 	int error;
 
+	if (!nss_nlwifili_registered) {
+		return true;
+	}
+
 	nss_nl_info_always("Exit NSS netlink wifili handler\n");
 
 	/*
@@ -175,5 +211,6 @@ bool nss_nlwifili_exit(void)
 		return false;
 	}
 
+	nss_nlwifili_registered = false;
 	return true;
 }
