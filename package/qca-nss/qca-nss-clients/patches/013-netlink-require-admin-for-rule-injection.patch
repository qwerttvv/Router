+++ b/netlink/nss_nlipv6.c
@@ -89,8 +89,8 @@ static struct genl_multicast_group nss_n
  * operation table called by the generic netlink layer based on the command
  */
 static struct genl_ops nss_nlipv6_ops[] = {
-	{.cmd = NSS_IPV6_TX_CREATE_RULE_MSG, .doit = nss_nlipv6_ops_create_rule,},	/* rule create */
-	{.cmd = NSS_IPV6_TX_DESTROY_RULE_MSG, .doit = nss_nlipv6_ops_destroy_rule,},	/* rule destroy */
+	{.cmd = NSS_IPV6_TX_CREATE_RULE_MSG, .doit = nss_nlipv6_ops_create_rule, .flags = GENL_ADMIN_PERM,},	/* rule create */
+	{.cmd = NSS_IPV6_TX_DESTROY_RULE_MSG, .doit = nss_nlipv6_ops_destroy_rule, .flags = GENL_ADMIN_PERM,},	/* rule destroy */
 };
 
